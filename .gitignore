# ===== Sarah-AI-Sushi .gitignore =====

# ===== Operating System Files =====
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ===== Editor Files =====
.vscode/
.idea/
*.sublime-*

# ===== Node.js (if using local dev tools) =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== Environment Variables (Constitution Principle III) =====
# NEVER commit .env files (contains API keys/secrets)
.env
.env.local
.env.development
.env.production
inject-env.js

# ===== Build Output (if migrating to build tools in Phase 2) =====
dist/
build/
out/

# ===== Log Files =====
*.log
logs/

# ===== Supabase CLI Temp Files =====
supabase/.temp/
supabase/.branches/

# ===== OS & Browser Temp Files =====
.cache/
*.tmp

# ===== Keep supabase/migrations (tracked in git) =====
# supabase/migrations/ is intentionally NOT ignored
